# Copy this file to .env.local for local work, then run: direnv allow
# Keep real values in .env.local or Fly secrets. Do not commit them.

export DATABASE_URL=ecto://postgres:postgres@localhost/platform_phx_dev
export DATABASE_DIRECT_URL=ecto://postgres:postgres@localhost/platform_phx_dev
export SECRET_KEY_BASE=replace_me
export PHX_HOST=127.0.0.1
export PORT=4000

# Browser auth
export VITE_PRIVY_APP_ID=
export VITE_PRIVY_APP_CLIENT_ID=
export PRIVY_VERIFICATION_KEY=

# Shared SIWA service
export SIWA_SERVER_BASE_URL=http://127.0.0.1:4100

# Base mainnet reads and Regent staking
export BASE_RPC_URL=
