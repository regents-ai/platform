# Private metrics, disabled locally unless you are testing the metrics listener.
export PROMETHEUS_METRICS_ENABLED=false
export PROMETHEUS_METRICS_PORT=9568

# Hosted company formation remains closed for public beta unless the
# hosted-company gate passes.
export AGENT_FORMATION_ENABLED=false

