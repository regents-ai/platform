# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Local editor / language server state.
/.elixir_ls/

# DS_store
.DS_Store

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
platform_phx-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# Ignore compressed and digested static output. Keep the plain source files.
/priv/static/**/*.gz
/priv/static/favicon-[0-9a-f]*.ico
/priv/static/fonts/*-[0-9a-f]*.woff2
/priv/static/images/*.png
/priv/static/images/*.jpeg
/priv/static/images/*.jpg
/priv/static/images/*-[0-9a-f]*.png
/priv/static/images/*-[0-9a-f]*.jpeg
/priv/static/images/*-[0-9a-f]*.jpg
/priv/static/images/*-[0-9a-f]*.svg
/priv/static/animata/
/priv/static/regent/*-[0-9a-f]*.svg
/priv/static/regent/sigils/*-[0-9a-f]*.svg
/priv/static/robots-[0-9a-f]*.txt
/priv/static/site-[0-9a-f]*.webmanifest
/priv/static/.DS_Store

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Local environment files for direnv / cutover work.
.env.local
.envrc

assets/esbuild-meta.json
assets/.DS_Store
shaders/animata/out/

# Draft planning docs and generated card variants do not belong in source control.
docs/*_plan.md
docs/*_notes.md
docs/*_spec.md
/priv/static/images/animata/cards/*-[0-9a-f]*.png
/layer2.md
/layer3.md
/design/
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.toc
